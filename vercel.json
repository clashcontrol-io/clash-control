{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "Cross-Origin-Embedder-Policy", "value": "require-corp" }
      ]
    }
  ],
  "functions": {
    "api/nl.js": { "maxDuration": 30 },
    "api/training.js": { "maxDuration": 10 },
    "api/project.js": { "maxDuration": 10 },
    "api/title.js": { "maxDuration": 30 }
  }
}
